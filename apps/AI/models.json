  "imageQuota": {
    "note": "Limites de génération d'images par utilisateur. Le forfait multiplie la base. Les limites horaires (hourly) se réinitialisent chaque heure ; les limites journalières (daily) se réinitialisent à minuit.",
    "forfaitMultiplier": {
      "1": 1.0,
      "2": 2.0,
      "3": 3.0,
      "4": 4.0,
      "5": 5.0
    },
    "forfaitNames": {
      "1": "Free",
      "2": "Plus",
      "3": "Pro",
      "4": "Premium",
      "5": "Premium+"
    },
    "models": {
      "flux": {
        "limitMode": "hourly",
        "baseLimit": 5
      },
      "zimage": {
        "limitMode": "hourly",
        "baseLimit": 3
      },
      "klein": {
        "limitMode": "hourly",
        "baseLimit": 1
      },
      "gptimage": {
        "limitMode": "daily",
        "baseLimit": 1
      },
      "gptimage-large": {
        "limitMode": "daily",
        "baseLimit": 1
      },
      "kontext": {
        "limitMode": "daily",
        "baseLimit": 1
      }
    },
    "firebasePath": "wikimind5/users/{uid}/imageQuota",
    "schema": {
      "windowHourly": "YYYY-MM-DDTHH  (ex: 2026-06-26T14)",
      "windowDaily": "YYYY-MM-DD     (ex: 2026-06-26)",
      "counts": {
        "{apiModel}": "nombre de générations dans la fenêtre courante (int)"
      }
    }
  },
  "imageRateLimit": {
    "note": "Remplacé par imageQuota. Conservé pour compatibilité.",
    "scope": "firebase-per-user"
  }
}
